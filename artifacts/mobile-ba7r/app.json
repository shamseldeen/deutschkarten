{
  "expo": {
    "name": "Ba7r DeutschKarten",
    "slug": "ba7r-deutschkarten",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ba7rdeutschkarten",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#f0f9ff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.deutschkarten.ba7r"
    },
    "android": {
      "package": "com.deutschkarten.ba7r",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0ea5e9"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      ["expo-router", {}],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#0284c7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
