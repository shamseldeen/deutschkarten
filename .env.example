# ══════════════════════════════════════════════════════════════
#  DeutschKarten — Environment Variables Template
#  انسخ هذا الملف إلى .env وأدخل قيمك الخاصة
# ══════════════════════════════════════════════════════════════

# ─── Database ─────────────────────────────────────────────────
# احصل عليه من: neon.tech (مجاني)
DATABASE_URL=postgresql://user:password@ep-xxx.aws.neon.tech/neondb?sslmode=require

# ─── Auth — Clerk ─────────────────────────────────────────────
# احصل عليهما من: clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ─── Session ──────────────────────────────────────────────────
# اكتب أي 32 حرف عشوائية (مثال: أي كلمات + أرقام)
SESSION_SECRET=your-super-secret-32-chars-minimum

# ─── AI — Gemini (الأساسي للترجمة وتوليد الكروت) ─────────────
# احصل عليه مجاناً من: aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ─── AI — OpenAI (احتياطي) ────────────────────────────────────
# احصل عليه من: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── Admin (اختياري) ──────────────────────────────────────────
# Clerk User IDs المسموح لهم بلوحة الإدارة (مفصولة بفاصلة)
ADMIN_USER_IDS=user_xxx,user_yyy

# ─── Server ───────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
