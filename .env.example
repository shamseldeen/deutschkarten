# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname

# ─── Auth (Clerk) ──────────────────────────────────────────
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# ─── Session ───────────────────────────────────────────────
SESSION_SECRET=at-least-32-random-characters-here

# ─── AI (اختياري — لتوليد الكروت) ─────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...

# ─── Admin (اختياري) ───────────────────────────────────────
ADMIN_USER_IDS=user_xxx,user_yyy

# ─── Server ────────────────────────────────────────────────
PORT=8080
NODE_ENV=production
